{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/main/.schema/devbox.schema.json",
  "packages": {
    "rustup":                                                                     "1.28.2",
    "nodejs":                                                                     "22.22.0",
    "pkg-config":                                                                 "0.29.2",
    "udev":                                                                       "252.5",
    "protobuf":                                                                   "33.5",
    "buf":                                                                        "1.64.0",
    "cargo-tarpaulin":                                                            "0.35.1",
    "licensure":                                                                  "0.5.1",
    "github:NixOS/nixpkgs/80d901ec0377e19ac3f7bb8c035201e2e098cc97#alsa-lib.dev": "",
    "openssl": {
      "version": "3.6.0",
      "outputs": ["dev"]
    }
  },
  "shell": {
    "init_hook": [
      "rustup default stable > /dev/null 2>&1",
      "rustup component add clippy rustfmt > /dev/null 2>&1"
    ]
  }
}
